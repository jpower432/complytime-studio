# SPDX-License-Identifier: Apache-2.0

FROM golang:1.25 AS builder

WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download
COPY . .

RUN CGO_ENABLED=0 go build -o /studio-ingest ./cmd/ingest/

FROM gcr.io/distroless/static-debian12:nonroot

COPY --from=builder /studio-ingest /studio-ingest

ENTRYPOINT ["/studio-ingest"]
