# SPDX-License-Identifier: Apache-2.0
#
# ComplyTime Studio Gateway Configuration
# Copy to .env and fill in required values.

# --- Gateway ---

# PORT=8080
# INTERNAL_PORT=8081

# MCP server URLs (set by docker-compose; override for standalone gateway)
# GEMARA_MCP_URL=http://localhost:3000
# ORAS_MCP_URL=http://localhost:3001

# Agent directory (JSON array of agent cards; set by Helm in k8s)
# AGENT_DIRECTORY=[]

# kagent controller A2A base URL. When set, all A2A traffic routes through
# the kagent controller instead of direct per-agent Services.
# KAGENT_A2A_URL=http://kagent-controller.kagent:8083
# KAGENT_AGENT_NAMESPACE=default

# A2A forward proxy URL. When set, all A2A traffic is forwarded to this URL
# instead of using the embedded proxy.
# A2A_PROXY_URL=

# --- Authentication ---

# Google OAuth — enables login and per-user token propagation to agents.
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_CALLBACK_URL=http://localhost:8080/auth/callback

# Session cookie encryption key (AES-256). 64 hex chars (32 bytes).
# Required when auth is enabled. Sessions won't survive restarts without it.
# Generate with: openssl rand -hex 32
# COOKIE_SECRET=

# Legacy alias for COOKIE_SECRET. Prefer COOKIE_SECRET for new deployments.
# COOKIE_SIGN_KEY=

# Comma-separated list of admin email addresses.
# When empty, all authenticated users get admin access.
# ADMIN_EMAILS=

# Static API token for seed scripts and CI. Required for POST /api/* without
# an OAuth session. WARNING: rotate from the default dev value before production.
# STUDIO_API_TOKEN=

# --- Security ---

# CORS allowed origins (comma-separated). Omit for same-origin only.
# CORS_ORIGINS=http://localhost:5173

# Set to any value to suppress the NetworkPolicy warning on the internal port.
# NETWORKPOLICY_ENFORCED=

# --- Data Store ---

# ClickHouse connection. Required for all store functionality.
# CLICKHOUSE_ADDR=localhost:9000
# CLICKHOUSE_USER=default
# CLICKHOUSE_PASSWORD=

# NATS URL for evidence event bus. When unset, posture checks and
# certification are disabled (evidence still ingests).
# NATS_URL=nats://localhost:4222

# --- Blob Storage ---

# S3-compatible object storage for evidence attachments.
# All BLOB_* vars must be set together or omitted together.
# BLOB_ENDPOINT=
# BLOB_BUCKET=
# BLOB_ACCESS_KEY=
# BLOB_SECRET_KEY=

# Use TLS for blob storage connections. Defaults to false (plain HTTP).
# BLOB_USE_SSL=false

# --- Certifier Pipeline ---

# Comma-separated known registries for provenance certifier.
# Empty = any source_registry passes (fail-open). Set explicitly in production.
# KNOWN_REGISTRIES=

# Comma-separated known engines for executor certifier.
# Empty = any engine_name passes (fail-open). Set explicitly in production.
# KNOWN_ENGINES=

# --- Registry ---

# Comma-separated insecure (HTTP) OCI registries for catalog seeding and publishing.
# REGISTRY_INSECURE=

# --- Model / Agent ---

# MODEL_PROVIDER=
# MODEL_NAME=
# GITHUB_ORG=
# GITHUB_REPO=complytime-studio
# AUTO_PERSIST_ARTIFACTS=true
