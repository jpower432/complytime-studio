# SPDX-License-Identifier: Apache-2.0

FROM golang:1.25 AS builder

WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download
COPY . .

RUN CGO_ENABLED=0 go build -o /studio-mcp ./cmd/studio-mcp/

FROM gcr.io/distroless/static-debian12:nonroot

COPY --from=builder /studio-mcp /studio-mcp

ENTRYPOINT ["/studio-mcp"]
